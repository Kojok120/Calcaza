# Site identity
NEXT_PUBLIC_SITE_URL=https://calcaza.com
NEXT_PUBLIC_SITE_NAME=Calcaza
NEXT_PUBLIC_SITE_TAGLINE=Calculadoras claras em português
NEXT_PUBLIC_SITE_OG_DESCRIPTION=

# Locale (override only if forking to another pt market)
NEXT_PUBLIC_SITE_LANG=pt-BR
NEXT_PUBLIC_SITE_LOCALE=pt_BR
NEXT_PUBLIC_SITE_DIR=ltr
NEXT_PUBLIC_SITE_INTL_LOCALE=pt-BR
NEXT_PUBLIC_SITE_CURRENCY=BRL

# Monetization
NEXT_PUBLIC_ADSENSE_CLIENT=ca-pub-XXXXXXXXXXXXXXXX

# Google Analytics 4 measurement ID (G-XXXXXXXXXX). Leave empty to skip tracking.
NEXT_PUBLIC_GA4_ID=

# Cloudflare Web Analytics site token (leave empty to skip beacon)
NEXT_PUBLIC_CLOUDFLARE_ANALYTICS_TOKEN=
